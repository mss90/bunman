{
	"name": "bunman",
	"private": true,
	"packageManager": "pnpm@10.33.4",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"typecheck": "turbo typecheck",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"db:generate": "pnpm --filter @bunman/db generate",
		"db:push": "pnpm --filter @bunman/db push",
		"db:seed": "pnpm --filter @bunman/db seed"
	},
	"pnpm": {
		"onlyBuiltDependencies": ["@biomejs/biome", "esbuild"]
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"turbo": "^2.3.3",
		"typescript": "^5.7.3"
	}
}
